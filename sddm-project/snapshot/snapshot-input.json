{
  "background": "assets/background.png",
  "greeting": "Welcome back",
  "clockFormat": "h:mm AP",
  "dateFormat": "dddd, MMMM d",
  "colors": {
    "background": "#1E1E2E",
    "foreground": "#CDD6F4",
    "accent": "#CBA6F7",
    "urgent": "#F38BA8",
    "muted": "#6C7086",
    "surface": "#11111B",
    "hover": "#313244",
    "border": "#CBA6F7"
  },
  "fontFamily": "CaskaydiaCove Nerd Font",
  "radius": 6,
  "layout": {
    "clockXOffset": 0,
    "clockYOffset": 0,
    "loginXOffset": 0,
    "loginYOffset": 0,
    "clockScalePercent": 100,
    "showDate": true,
    "dateScalePercent": 100,
    "clockDateSpacing": 8,
    "clockShadowOpacityPercent": 100,
    "clockShadowXOffset": 3,
    "clockShadowYOffset": 3,
    "loginScalePercent": 100,
    "loginPanelWidth": 430,
    "loginPanelSpacing": 14
  },
  "clockAppearance": {
    "useThemeColors": true,
    "timeColor": "#CDD6F4",
    "dateColor": "#CDD6F4",
    "shadowColor": "#000000"
  },
  "fontSelection": {
    "mode": "theme",
    "family": "CaskaydiaCove Nerd Font"
  },
  "themeSelection": {
    "mode": "current",
    "name": "CatppuccinMochaTheme"
  },
  "wallpaperSelection": {
    "mode": "current",
    "path": ""
  }
}
